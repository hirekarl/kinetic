# Copy this file to .env and fill in values.
# Never commit .env to version control.

# Required: Google Gemini API key for LLM parsing layer
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the backend API base URL (defaults to same-origin / Vite proxy)
# In production on Render, set VITE_API_BASE_URL to your Render API service URL:
# VITE_API_BASE_URL=https://kinetic-api.onrender.com
VITE_API_BASE_URL=
