# Copy this file to .env and fill in values.
# Never commit .env to version control.

# Required: Google Gemini API key for LLM parsing layer
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the backend API base URL (defaults to same-origin / Vite proxy)
# In production on Render, set VITE_API_BASE_URL to your Render API service URL:
# VITE_API_BASE_URL=https://kinetic-api.onrender.com
VITE_API_BASE_URL=

# Persistence Layer: SQLite local storage path (used only for the "default" tenant; named tenants use kinetic_{tenant}.db)
SQLITE_DB_PATH=./kinetic.db

# Auth: JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-long-random-string-here

# Auth: path to tenant credentials TOML (defaults to ./credentials.toml)
# CREDENTIALS_PATH=./credentials.toml

# Database: PostgreSQL connection string (Render injects this automatically via DATABASE_URL fromDatabase binding)
# Omit for local dev — app falls back to SQLite when unset.
# DATABASE_URL=postgresql://user:pass@localhost/kinetic

# CORS: frontend URL for production (added to allow_origins at startup)
# Omit for local dev — Vite proxy handles cross-origin requests.
# FRONTEND_URL=https://your-frontend.onrender.com

# Logging: force JSON log output locally (structlog uses colorized ConsoleRenderer by default)
# Render sets RENDER=true automatically, which also triggers JSON output.
# LOG_FORMAT=json
