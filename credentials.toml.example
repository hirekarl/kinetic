# Kinetic tenant credentials — copy to credentials.toml and fill in real bcrypt hashes.
# Generate a hash:  uv run python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
# credentials.toml is gitignored and must never be committed.

[tenants.demo]
password_hash = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
db_path = "./kinetic_demo.db"
display_name = "Demo"

[tenants.personal]
password_hash = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
db_path = "./kinetic_personal.db"
display_name = "Personal"
